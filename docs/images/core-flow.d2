# Kalypso Core capability flow diagram
# Written in D2 (https://d2lang.com)

vars: {
  d2-config: {
    layout-engine: elk
    theme-id: 300
  }
}

direction: right

style.fill: transparent

classes: {
  purple-box: {
    style: {
      font-size: 18
      font-color: "#FFFFFF"
      fill: "#4F46E5"
      stroke: "#8B5CF6"
      border-radius: 12
      stroke-width: 0
      bold: true
    }
  }

  darker-box: {
    style: {
      font-size: 18
      font-color: "#FFFFFF"
      fill: "#3d3c5f"
      border-radius: 12
      stroke-width: 0
      bold: true
    }
  }
  generated-node: {
    style: {
      font-size: 14
      font-color: "#d13030"
      # fill: "#3d3c5f"
      border-radius: 12
      stroke-width: 0
      bold: true
    }
  }

  connector: {
    style: {
      stroke: "#4F46E5"
      font-color: "#6366F1"
      stroke-dash: 5
    }
  }
}

core_cr: "Core CR\n(kalypso.lmoet.io/v1alpha2)" {
  class: purple-box
  spec: |`yaml
    kind: Core
    spec:
      computeType: Deployment|StatefulSet|DaemonSet
      image: string
      port: int
      # ...
  `|
}

podspec_rgd: "PodSpec RGD\n(Chained helper RGD)" {
  grid-columns: 1

  class: darker-box

  sa: "ServiceAccount" {
    class: generated-node
    label: "ServiceAccount\nincludeWhen: serviceAccount.create"
  }
  cm: "ConfigMap" {
    class: generated-node
    label: "ConfigMap\nincludeWhen: configMap.enabled"
  }
  sec: "Secret" {
    class: generated-node
    label: "Secret\nincludeWhen: secret.enabled"
  }
  pt: "PodTemplate" {
    class: generated-node
    label: "PodTemplate\n(generates PodSpec status)"
  }
}

workloads: "Compute Type (Exclusive)" {
  grid-columns: 1

  class: darker-box

  dep: "Deployment" {
    class: generated-node
    label: "Deployment\nincludeWhen: computeType == 'Deployment'"
  }
  ss: "StatefulSet" {
    class: generated-node
    label: "StatefulSet\nincludeWhen: computeType == 'StatefulSet'"
  }
  ds: "DaemonSet" {
    class: generated-node
    label: "DaemonSet\nincludeWhen: computeType == 'DaemonSet'"
  }
}

addons: "(Conditional)" {
  grid-columns: 1

  class: darker-box

  hpa: "HPA v2" {
    class: generated-node
    label: "HPA v2\nincludeWhen: autoscaling.enabled"
  }
  pdb: "PodDisruptionBudget" {
    class: generated-node
    label: "PodDisruptionBudget\nincludeWhen: pdb.enabled"
  }
  netpol: "NetworkPolicy" {
    class: generated-node
    label: "NetworkPolicy\nincludeWhen: networkPolicy.enabled"
  }
  role: "Role & Binding" {
    class: generated-node
    label: "Role & Binding\nincludeWhen: rbac.rules"
  }
  crole: "ClusterRole & Binding" {
    class: generated-node
    label: "ClusterRole & Binding\nincludeWhen: rbac.clusterRules"
  }
}

# Connections
core_cr -> podspec_rgd: "Chains to" {
  class: connector
}

podspec_rgd -> workloads: {
  class: connector
}

core_cr -> addons: "Conditionally enables" {
  class: connector
}

