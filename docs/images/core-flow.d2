#   class: conditional-edge
# }

# input.core_cr -> addons: "Triggers if enabled" {
#   class: conditional-edge
# }

# workloads -> addons.hpa: "TargetRef" {
#   class: flow-edge
# }

# workloads -> addons.pdb: "Selector match" {
#   class: flow-edge
# }

# internal.podspec_rgd.sa -> addons.role: "Binds to" {
#   class: flow-edge
# }

# internal.podspec_rgd.sa -> addons.crole: "Binds to" {
#   class: flow-edge
# }
